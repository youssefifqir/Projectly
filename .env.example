# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme_db_password

# ── Application Admin ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@projectly.com
ADMIN_PASSWORD=Admin@12345!

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
GRAFANA_ROOT_URL=http://localhost:3000



# ── Email (Resend SMTP) ───────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_YOUR_RESEND_API_KEY
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Projectly
